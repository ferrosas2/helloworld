# RO-Fraud environment configuration TEMPLATE.
#
# Copy this file to `.env` and fill in your real values:
#     cp .env.example .env        (macOS/Linux)
#     copy .env.example .env      (Windows cmd)
#
# The real `.env` is gitignored and must NEVER be committed — these are sensitive
# infrastructure identifiers for your GCP project.

# Google Cloud project that owns all resources.
GCP_PROJECT_ID=your-gcp-project-id

# Region for Vertex AI, GCS, and Cloud Run.
GCP_REGION=us-central1

# Globally unique GCS bucket holding the embedding vectors (JSONL).
GCS_BUCKET_NAME=your-gcs-bucket-name

# Vertex AI Vector Search index ID.
# Use `placeholder` until the index is created, then replace with the real ID
# from: gcloud ai indexes list --region=us-central1
VERTEX_INDEX_ID=placeholder

# Vertex AI Vector Search index endpoint ID.
# Use `placeholder` until the endpoint is deployed, then replace with the real ID
# from: gcloud ai index-endpoints list --region=us-central1
VERTEX_ENDPOINT_ID=placeholder
